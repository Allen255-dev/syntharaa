# Copy this file to .env and fill in whichever providers you want to enable.
# You only need ONE to get Synthara running — models from providers without
# a key simply show as "unavailable" in the app, nothing breaks.

PORT=3000

# Database — leave both blank for local dev (writes to data/synthara.db,
# zero setup needed). Required if deploying to Vercel or anywhere else
# without a persistent disk — see README for how to create a free Turso DB.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Google Gemini — free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — free tier: https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter — free models: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: tune abuse protection (requests per window per IP)
CHAT_RATE_LIMIT=40
UPLOAD_RATE_LIMIT=20
SHARE_RATE_LIMIT=15
AUTH_RATE_LIMIT=20
